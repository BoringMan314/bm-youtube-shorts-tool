{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "version": "0.1.1",
  "description": "__MSG_extDescription__",
  "default_locale": "zh_TW",
  "homepage_url": "https://github.com/BoringMan314/bm-youtube-shorts-tool",
  "icons": {
    "128": "icons/icon.png"
  },
  "permissions": [
    "downloads",
    "tabs",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://*.googlevideo.com/*",
    "https://*.youtube.com/*"
  ],
  "action": {
    "default_icon": {
      "128": "icons/icon.png"
    },
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/shorts/*",
        "https://youtube.com/shorts/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    }
  ]
}
